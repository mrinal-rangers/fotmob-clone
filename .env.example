# ─── Development Configuration ───────────────────────────────────────────────
# Copy this to .env and fill in your local values.

# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fotmob_clone?schema=public"

# JWT Authentication
JWT_SECRET="dev-jwt-secret-change-in-production"
JWT_EXPIRES_IN=24h

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Comma-separated list of admin emails (Google Sign-In only)
ADMIN_EMAILS="fotmob437@gmail.com"

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug
