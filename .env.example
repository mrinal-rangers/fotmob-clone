# ─── Development Configuration ───────────────────────────────────────────────
# Copy this to .env and fill in your local values, or set NODE_ENV=dev to load this file directly.

# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fotmob_clone?schema=public"

# Authentication
JWT_SECRET="dev-jwt-secret-change-in-production"
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug
