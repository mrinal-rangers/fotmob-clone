# ─── FotMob Clone Configuration ─────────────────────────────────────────────
# Copy this to .env and fill in your local values.

# Server
FOTMOB_PORT=3000
FOTMOB_CORS_ORIGIN=http://localhost:5173

# Database
FOTMOB_DB_URL="postgresql://postgres:postgres@localhost:5432/fotmob_clone?schema=public"

# JWT
FOTMOB_JWT_SECRET="dev-jwt-secret-change-in-production"
FOTMOB_JWT_EXPIRES_IN=24h

# Google OAuth — https://console.cloud.google.com/apis/credentials
FOTMOB_AUTH_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Admin emails allowed to sign in via Google (comma-separated)
FOTMOB_AUTH_ADMIN_EMAILS="your-admin@gmail.com"

# Seed admin — used by prisma/seed.ts for local password auth
FOTMOB_SEED_ADMIN_EMAIL="admin@fotmob.com"
FOTMOB_SEED_ADMIN_PASSWORD="admin123"

# Logging
FOTMOB_LOG_LEVEL=debug
