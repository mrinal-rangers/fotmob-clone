# ─── Development Configuration ───────────────────────────────────────────────
# Copy this to .env and fill in your local values.

# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fotmob_clone?schema=public"

# JWT Authentication
JWT_SECRET="dev-jwt-secret-change-in-production"
JWT_EXPIRES_IN=24h

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Admin emails allowed to sign in via Google
ADMIN_EMAILS="your-admin@gmail.com"

# Seed admin credentials (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@fotmob.com"
SEED_ADMIN_PASSWORD="admin123"

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug
