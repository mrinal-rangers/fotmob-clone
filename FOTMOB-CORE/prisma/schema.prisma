generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeagueType {
  LEAGUE
  CUP
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum EventType {
  GOAL
  OWN_GOAL
  PENALTY
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
  INJURY
  MISSED_PENALTY
  HIT_POST
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum TransferType {
  PERMANENT
  LOAN
  FREE_TRANSFER
}

enum NewsCategory {
  TRANSFERS
  MATCH_REPORT
  RUMOR
  OFFICIAL
  ANALYSIS
  GENERAL
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

model League {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  logoUrl   String?
  country   String
  type      LeagueType @default(LEAGUE)
  season    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  matches     Match[]
  standings   Standing[]
  playerStats PlayerStats[]
  news        News[]

  @@map("leagues")
}

model Team {
  id          String   @id @default(uuid())
  name        String
  shortName   String?
  slug        String   @unique
  logoUrl     String?
  country     String?
  stadium     String?
  foundedYear Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  homeMatches      Match[]       @relation("HomeMatches")
  awayMatches      Match[]       @relation("AwayMatches")
  homeEvents       MatchEvent[]  @relation("HomeTeamEvents")
  players          Player[]
  standings        Standing[]
  playerStats      PlayerStats[]
  transfersOut     Transfer[]    @relation("FromTeam")
  transfersIn      Transfer[]    @relation("ToTeam")

  @@map("teams")
}

model Player {
  id           String         @id @default(uuid())
  name         String
  slug         String         @unique
  position     PlayerPosition
  nationality  String?
  dateOfBirth  DateTime?
  height       Int?
  weight       Int?
  shirtNumber  Int?
  photoUrl     String?
  teamId       String?
  team         Team?          @relation(fields: [teamId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  events           MatchEvent[]    @relation("PlayerEvents")
  assists          MatchEvent[]    @relation("AssistEvents")
  playerStats      PlayerStats[]
  transfers        Transfer[]

  @@map("players")
}

model Match {
  id          String      @id @default(uuid())
  homeTeamId  String
  awayTeamId  String
  leagueId    String
  round       Int?
  date        DateTime
  status      MatchStatus @default(SCHEDULED)
  minute      Int?
  homeScore   Int         @default(0)
  awayScore   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  homeTeam Team  @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeam Team  @relation("AwayMatches", fields: [awayTeamId], references: [id])
  league   League @relation(fields: [leagueId], references: [id])
  events   MatchEvent[]

  @@map("matches")
}

model MatchEvent {
  id             String    @id @default(uuid())
  matchId        String
  teamId         String
  playerId       String?
  assistPlayerId String?
  type           EventType
  minute         Int
  extraMinute    Int?
  detail         String?
  createdAt      DateTime  @default(now())

  match       Match   @relation(fields: [matchId], references: [id])
  team        Team    @relation("HomeTeamEvents", fields: [teamId], references: [id])
  player      Player? @relation("PlayerEvents", fields: [playerId], references: [id])
  assistPlayer Player? @relation("AssistEvents", fields: [assistPlayerId], references: [id])

  @@map("match_events")
}

model Standing {
  id            String @id @default(uuid())
  leagueId      String
  teamId        String
  season        String
  position      Int
  played        Int    @default(0)
  wins          Int    @default(0)
  draws         Int    @default(0)
  losses        Int    @default(0)
  goalsFor      Int    @default(0)
  goalsAgainst  Int    @default(0)
  goalDifference Int   @default(0)
  points        Int    @default(0)
  form          String?

  league League @relation(fields: [leagueId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([leagueId, teamId])
  @@map("standings")
}

model PlayerStats {
  id           String         @id @default(uuid())
  playerId     String
  leagueId     String
  teamId       String
  season       String
  goals        Int            @default(0)
  assists      Int            @default(0)
  appearances  Int            @default(0)
  minutesPlayed Int           @default(0)
  yellowCards  Int            @default(0)
  redCards     Int            @default(0)
  cleanSheets  Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  player Player @relation(fields: [playerId], references: [id])
  league League @relation(fields: [leagueId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([playerId, leagueId, season])
  @@map("player_stats")
}

model Transfer {
  id         String       @id @default(uuid())
  playerId   String
  fromTeamId String?
  toTeamId   String
  date       DateTime
  fee        Decimal?     @db.Decimal(12, 2)
  feeDisplay String?
  type       TransferType @default(PERMANENT)
  createdAt  DateTime     @default(now())

  player   Player @relation(fields: [playerId], references: [id])
  fromTeam Team?  @relation("FromTeam", fields: [fromTeamId], references: [id])
  toTeam   Team   @relation("ToTeam", fields: [toTeamId], references: [id])

  @@map("transfers")
}

model News {
  id          String       @id @default(uuid())
  title       String
  slug        String       @unique
  content     String
  excerpt     String?
  imageUrl    String?
  category    NewsCategory @default(GENERAL)
  leagueId    String?
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  league League? @relation(fields: [leagueId], references: [id])

  @@map("news")
}

model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  googleId     String?   @unique
  passwordHash String?
  name         String
  picture      String?
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())

  @@map("admins")
}

enum FollowEntityType {
  PLAYER
  TEAM
  LEAGUE
  COUNTRY
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?

  theme      String @default("system")
  language   String @default("en")
  unitSystem String @default("metric")
  timezone   String @default("UTC")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  follows UserFollow[]

  @@map("users")
}

model UserFollow {
  id         String           @id @default(uuid())
  userId     String
  entityType FollowEntityType
  entityId   String
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@map("user_follows")
}
